# ============================================
# Environment Variables Template
# Copy this file to .env and fill in values
# ============================================

# ---- DATABASE (Neon PostgreSQL) ----
# Get this from: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ---- SERVER ----
PORT=3001
NODE_ENV=development

# ---- FRONTEND API URL ----
# In production: your Vercel domain
# In development: http://localhost:3001
VITE_API_URL=http://localhost:3001

# ---- GOOGLE CLOUD STORAGE (Optional - for file uploads) ----
# Get from: Google Cloud Console → Service Account
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ---- ADMIN AUTH ----
# Default admin credentials (change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=change-this-to-a-random-secret-in-production

# ---- CORS ----
# Your frontend URL (for production, use your Vercel domain)
CORS_ORIGIN=http://localhost:5173
