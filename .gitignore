# ============================================
# .gitignore for Hindi News Portal Monorepo
# ============================================

# ---- Compiled Output ----
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo
.expo-shared
build/

# ---- Dependencies ----
node_modules/
.pnpm-store/

# ---- Environment Variables (NEVER commit these!) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ---- IDEs and Editors ----
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ---- OS Files ----
.DS_Store
Thumbs.db
*.swp
*.swo

# ---- Logs ----
*.log
npm-debug.log*
yarn-error.log
pnpm-debug.log*
/connect.lock
/coverage
/libpeerconnection.log
testem.log

# ---- Testing ----
coverage/
.nyc_output/

# ---- Misc ----
/.sass-cache
/typings
*.pem
*.key
service-account.json
google-credentials.json

# ---- Replit Specific (DO NOT PUSH) ----
.cache/
.local/
.replit
.replitignore
.agents/
.replit-artifact/

# ---- Cursor ----
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
